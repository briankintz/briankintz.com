---
// "Notebook" base layout: dot-grid paper, self-hosted fonts, Header + Footer.
// Pages own their <main>; the layout only provides the chrome.
import '@fontsource/aleo/latin-500.css'
import '@fontsource/aleo/latin-600.css'
import '@fontsource/aleo/latin-700.css'
import '@fontsource/aleo/latin-500-italic.css'
import '@fontsource/aleo/latin-600-italic.css'
import '@fontsource/lato/latin-400.css'
import '@fontsource/lato/latin-700.css'
import '../styles/tokens.css'
import '../styles/notebook.css'

import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Analytics from '@vercel/analytics/astro'

interface Props {
  title: string
  description: string
  // 'topo' swaps the dot-grid paper for the Hochries contour background (index + side-quests)
  bg?: 'dots' | 'topo'
}

const { title, description, bg = 'dots' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Vercel Web Analytics — same-origin (/_vercel/insights/*) on Vercel; explicit mode
         because a static Astro build doesn't expose NODE_ENV to the client for auto-detection -->
    <Analytics mode={import.meta.env.PROD ? 'production' : 'development'} />
  </head>
  <body class:list={[bg === 'topo' && 'bg-topo']}>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
