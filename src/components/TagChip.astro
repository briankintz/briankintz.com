---
// Recipe tag chip — orange annotation accent, fixed vocabulary only.
interface Props {
  tag: string
}

const { tag } = Astro.props
---

<span class="rtag">{tag}</span>

<style>
  .rtag {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-orange-text);
    background: var(--color-orange-tag);
    border-radius: var(--radius-tag);
    padding: 3px 10px;
  }
</style>
