---
// The only global nav. Sticky, blurred paper, purple active state — per the Notebook design system.
const path = Astro.url.pathname
const inSection = (base: string) => path === base || path.startsWith(base + '/')
const isCookbook = inSection('/cookbook')
const isSideQuests = inSection('/side-quests')
---

<!-- TEMP(logo-toggle): apply the stored logo variant before paint to avoid a flash. Remove with the rest of the toggle. -->
<script is:inline>
  try {
    var l = localStorage.getItem('logo')
    if (l === 'a' || l === 'b') document.documentElement.dataset.logo = l
  } catch (e) {}
</script>

<header>
  <div class="wrap nav">
    <a class="logo" href="/">
      {/* TEMP(logo-toggle): two candidate wordmarks; CSS shows one per :root[data-logo] */}
      <span class="logo-variant v-a">brian<span class="dot">.</span>kintz</span>
      <span class="logo-variant v-b">brian<span class="ink-k">kintz</span></span>
    </a>
    <nav class="nav-links" aria-label="Site">
      <a href="/#work">Work</a>
      <a href="/side-quests" class:list={{ active: isSideQuests }} aria-current={isSideQuests ? 'page' : undefined}
        >Side Quests</a
      >
      <a href="/cookbook" class:list={{ active: isCookbook }} aria-current={isCookbook ? 'page' : undefined}>Cookbook</a
      >
    </nav>
  </div>
</header>

<!-- TEMP(logo-toggle): floating compare switch — delete this button, the two scripts, the .logo-variant/.dot/.ink-k/#logo-toggle styles, and restore the single <a class="logo"> wordmark once the logo is chosen. -->
<button id="logo-toggle" type="button" aria-label="Toggle logo variant"
  >logo <b>B</b> — brian<span class="tk">kintz</span></button
>
<script is:inline>
  ;(function () {
    var btn = document.getElementById('logo-toggle')
    if (!btn) return
    var root = document.documentElement
    var cur = function () {
      return root.dataset.logo === 'a' ? 'a' : 'b'
    }
    var render = function () {
      var a = cur() === 'a'
      btn.innerHTML = a
        ? 'logo <b>A</b> — brian<span class="tk">.</span>kintz'
        : 'logo <b>B</b> — brian<span class="tk">kintz</span>'
    }
    render()
    btn.addEventListener('click', function () {
      var next = cur() === 'a' ? 'b' : 'a'
      root.dataset.logo = next
      try {
        localStorage.setItem('logo', next)
      } catch (e) {}
      render()
    })
  })()
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    /* mockup value rgba(252,251,247,.92) = --color-paper at 92% */
    background: color-mix(in srgb, var(--color-paper) 92%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-line);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 62px;
  }

  .logo {
    font-family: var(--font-slab);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-ink);
    text-decoration: none;
  }

  /* TEMP(logo-toggle): default = B; :root[data-logo="a"] flips to A */
  .logo-variant.v-a {
    display: none;
  }
  :root[data-logo='a'] .logo-variant.v-a {
    display: inline;
  }
  :root[data-logo='a'] .logo-variant.v-b {
    display: none;
  }
  .logo .dot {
    color: var(--color-orange);
  }
  .logo .ink-k {
    color: var(--color-purple);
  }

  /* TEMP(logo-toggle): floating compare switch */
  #logo-toggle {
    position: fixed;
    bottom: 16px;
    right: 16px;
    z-index: 50;
    font-family: var(--font-slab);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-soft);
    background: var(--color-card);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-tag);
    padding: 8px 14px;
    cursor: pointer;
    box-shadow: var(--shadow-hover);
  }
  #logo-toggle b {
    color: var(--color-ink);
  }
  #logo-toggle .tk {
    color: var(--color-purple);
  }
  :root[data-logo='a'] #logo-toggle .tk {
    color: var(--color-orange);
  }

  .nav-links {
    display: flex;
    gap: 24px;
  }

  .nav-links a {
    font-size: 14.5px;
    font-weight: 500;
    color: var(--color-soft);
    text-decoration: none;
  }

  .nav-links a:hover {
    color: var(--color-purple);
  }

  .nav-links a.active {
    color: var(--color-purple);
    font-weight: 700;
  }
</style>
