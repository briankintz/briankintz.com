---
// Watermark that bleeds off the card's bottom-right corner (clipped by the card's overflow:hidden).
// PLACEHOLDER GLYPH — the real per-quest line icons are TBD; only the mechanism is final here
// (size/position/opacity/accent + non-scaling hairline stroke). To finish: give each `name` its own
// paths — see the ICONS map in design_handoff_side_quests. Colour + opacity are set by QuestCard.
interface Props {
  name: string
  tier: 'hero' | 'feature' | 'normal'
}
const { name, tier } = Astro.props
const size = tier === 'hero' ? 300 : tier === 'feature' ? 232 : 172
---

<svg
  class:list={['qi', tier]}
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="2.2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  data-icon={name}
>
  <rect x="4" y="4" width="16" height="16" rx="3.5"></rect>
  <circle cx="12" cy="12" r="3.2"></circle>
</svg>

<style>
  .qi {
    position: absolute;
    pointer-events: none;
  }
  /* constant hairline no matter how large the svg is scaled */
  .qi :global(*) {
    vector-effect: non-scaling-stroke;
  }
  .qi.hero {
    right: -24px;
    bottom: -56px;
  }
  .qi.feature,
  .qi.normal {
    right: -40px;
    bottom: -46px;
  }
</style>
