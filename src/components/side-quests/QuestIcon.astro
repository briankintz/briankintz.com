---
// Line-icon watermark that bleeds off the card's bottom-right corner (clipped by the card's
// overflow:hidden). Colour + opacity are set by QuestCard; the glyph comes from the shared ICONS map.
import { ICONS } from './quest-icons'
interface Props {
  name: string
  tier: 'hero' | 'feature' | 'normal'
}
const { name, tier } = Astro.props
const size = tier === 'hero' ? 300 : tier === 'feature' ? 232 : 172
const inner = ICONS[name] ?? ''
---

<svg
  class:list={['qi', tier]}
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="2.2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  data-icon={name}
  set:html={inner}
/>

<style>
  .qi {
    position: absolute;
    pointer-events: none;
  }
  /* constant hairline no matter how large the svg is scaled */
  .qi :global(*) {
    vector-effect: non-scaling-stroke;
  }
  .qi.hero {
    right: -24px;
    bottom: -56px;
  }
  .qi.feature,
  .qi.normal {
    right: -40px;
    bottom: -46px;
  }
</style>
