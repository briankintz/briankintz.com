---
// The single icon component: stroke-based inline SVG, currentColor.
// Paths copied from handoff/mockups/ (arrow drawn to match; mockups use the → character).
// Size via CSS on the consumer, e.g. `.socials :global(svg) { width: 17px; height: 17px }`.
interface Props {
  name: 'github' | 'linkedin' | 'instagram' | 'bulb' | 'arrow'
}

const { name } = Astro.props

const icons: Record<Props['name'], { strokeWidth: number; svg: string }> = {
  github: {
    strokeWidth: 1.7,
    svg: '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.9a3.4 3.4 0 00-.9-2.6c3.1-.3 6.4-1.5 6.4-7A5.4 5.4 0 0020 4.8 5 5 0 0019.9 1s-1.2-.3-3.9 1.4a13.4 13.4 0 00-7 0C6.3.7 5.1 1 5.1 1A5 5 0 005 4.8a5.4 5.4 0 00-1.5 3.7c0 5.4 3.3 6.7 6.4 7a3.4 3.4 0 00-.9 2.6V22"/>',
  },
  linkedin: {
    strokeWidth: 1.7,
    svg: '<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4V9h4v1.5A6 6 0 0116 8z"/><rect x="2" y="9" width="4" height="12" rx=".5"/><circle cx="4" cy="4" r="2"/>',
  },
  instagram: {
    strokeWidth: 1.7,
    svg: '<rect x="2.5" y="2.5" width="19" height="19" rx="5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.6" cy="6.4" r=".9" fill="currentColor" stroke="none"/>',
  },
  bulb: {
    strokeWidth: 1.8,
    svg: '<path d="M12 2a7 7 0 00-4 12.7c.6.5 1 1.2 1 2V18h6v-1.3c0-.8.4-1.5 1-2A7 7 0 0012 2z"/><path d="M9 21h6"/>',
  },
  arrow: {
    strokeWidth: 1.8,
    svg: '<path d="M4 12h15"/><path d="M13 6l6 6-6 6"/>',
  },
}
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={icons[name].strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={icons[name].svg}
/>
