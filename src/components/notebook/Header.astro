---
// The only global nav. Sticky, blurred paper, purple active state — per handoff/mockups/.
// Lives in components/notebook/ until the old homepage (and its Header.astro) is retired.
const path = Astro.url.pathname
const isCookbook = path === '/cookbook' || path.startsWith('/cookbook/')
const isSideQuests = path === '/side-quests' || path.startsWith('/side-quests/')
---

<header>
  <div class="wrap nav">
    <a class="logo" href="/">Brian<span>Kintz</span></a>
    <nav class="nav-links" aria-label="Site">
      <a href="/#work">Work</a>
      <a href="/cookbook" class:list={{ active: isCookbook }} aria-current={isCookbook ? 'page' : undefined}>Cookbook</a
      >
      <a href="/side-quests" class:list={{ active: isSideQuests }} aria-current={isSideQuests ? 'page' : undefined}
        >Side Quests</a
      >
    </nav>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    /* mockup value rgba(252,251,247,.92) = --color-paper at 92% */
    background: color-mix(in srgb, var(--color-paper) 92%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-line);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 62px;
  }

  .logo {
    font-family: var(--font-slab);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-ink);
    text-decoration: none;
  }

  .logo span {
    color: var(--color-purple);
  }

  .nav-links {
    display: flex;
    gap: 24px;
  }

  .nav-links a {
    font-size: 14.5px;
    font-weight: 500;
    color: var(--color-soft);
    text-decoration: none;
  }

  .nav-links a:hover {
    color: var(--color-purple);
  }

  .nav-links a.active {
    color: var(--color-purple);
    font-weight: 700;
  }
</style>
