---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Icon from '../../components/Icon.astro'
import IngredientList from '../../components/IngredientList.astro'
import Highlight from '../../components/Highlight.astro'
import LinkButton from '../../components/LinkButton.astro'
import TagChip from '../../components/TagChip.astro'
import { CATEGORY_LABELS, effortDots, publishedRecipes, yieldMeta } from '../../lib/recipes'

export async function getStaticPaths() {
  // prev/next follow the cookbook index's browsing order (category, then title)
  const recipes = await publishedRecipes()
  return recipes.map((recipe, i) => ({
    params: { slug: recipe.id },
    props: { recipe, prev: recipes[i - 1], next: recipes[i + 1] },
  }))
}

const { recipe, prev, next } = Astro.props
const { title, tagline, category, effort, tags, tip } = recipe.data
const { label: yieldLabel, value: yieldValue } = yieldMeta(recipe.data)

// Split the rendered markdown into its `## <heading>` sections: split with a capture
// group yields [preamble, heading, body, heading, body, ...].
const parts = (recipe.rendered?.html ?? '').split(/<h2[^>]*>([\s\S]*?)<\/h2>/)
const preamble = parts[0].trim() // e.g. hamburger-buns' attribution blockquote above ## Ingredients
const sections = []
for (let i = 1; i < parts.length; i += 2) sections.push({ heading: parts[i].trim(), html: parts[i + 1] })

const ingredients = sections.find((s) => s.heading === 'Ingredients')
const method = sections.find((s) => s.heading === 'Method')
const extras = sections.filter((s) => s !== ingredients && s !== method) // Variations, Serving Ideas, ...
// Drafts are excluded from routes, so every published recipe must follow the body convention.
if (!ingredients || !method) throw new Error(`${recipe.id}: recipe body needs ## Ingredients and ## Method`)

// Highlighter swipe on the last word of the title — once per page, as in the mockup
const words = title.split(' ')
const hlWord = words.pop()
const titleLead = words.join(' ')

const categoryLabel = CATEGORY_LABELS[category]
---

<BaseLayout
  title={`${title} — The Cookbook — Brian Kintz`}
  description={`${title}: ${tagline}. A recipe from Brian's cookbook.`}
>
  <main class="wrap">
    <div class="r-hero">
      <a class="back" href="/cookbook">← All recipes</a>
      <h1>{titleLead}{titleLead && ' '}<Highlight>{hlWord}</Highlight></h1>
      <p class="tagline">{tagline}</p>
      {preamble && <div class="preamble" set:html={preamble} />}
      {
        tags.length > 0 && (
          <div class="tags-row">
            {tags.map((tag) => (
              <TagChip tag={tag} />
            ))}
          </div>
        )
      }
      <div class="meta-strip">
        <div class="meta-cell"><b>Category</b><span>{categoryLabel}</span></div>
        <div class="meta-cell"><b>Effort</b><span class="dots">{effortDots(effort)}</span></div>
        <div class="meta-cell"><b>{yieldLabel}</b><span>{yieldValue}</span></div>
      </div>
    </div>

    <div class="r-body">
      <aside class="ing-card">
        <h2>Ingredients</h2>
        <IngredientList html={ingredients.html} />
      </aside>

      <article class="method">
        <h2>Method</h2>
        {
          tip && (
            <div class="tip">
              <Icon name="bulb" />
              <p>{tip}</p>
            </div>
          )
        }
        <div class="steps" set:html={method.html} />
        {
          extras.map((section) => (
            <section class="extra">
              <h2>{section.heading}</h2>
              <div class="prose" set:html={section.html} />
            </section>
          ))
        }
      </article>
    </div>

    <nav class="r-nav" aria-label="More recipes">
      {
        prev ? (
          <LinkButton class="r-btn" href={`/cookbook/${prev.id}`}>
            ← Previous: {prev.data.title}
          </LinkButton>
        ) : (
          <span />
        )
      }
      {
        next && (
          <LinkButton class="r-btn" href={`/cookbook/${next.id}`}>
            Next: {next.data.title} →
          </LinkButton>
        )
      }
    </nav>
  </main>
</BaseLayout>

<style>
  /* ---------- hero ---------- */
  .r-hero {
    padding: 72px 0 40px;
  }

  .back {
    display: block;
    width: fit-content;
    font-size: 13.5px;
    font-weight: 700;
    color: var(--color-purple);
    text-decoration: none;
    margin-bottom: 20px;
  }

  .back:hover {
    text-decoration: underline;
  }

  h1 {
    font-family: var(--font-slab);
    font-size: clamp(36px, 5.5vw, 56px);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .tagline {
    font-family: var(--font-slab);
    font-style: italic;
    font-size: 19px;
    color: var(--color-soft);
    margin-top: 8px;
  }

  .preamble {
    margin-top: 14px;
  }

  .preamble :global(p) {
    font-family: var(--font-slab);
    font-style: italic;
    font-size: 14.5px;
    color: var(--color-soft);
  }

  /* Content links are structural — purple, everywhere in the recipe body */
  .preamble :global(a),
  .r-body :global(a) {
    color: var(--color-purple);
  }

  .tags-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 16px;
  }

  /* Meta strip — one of the two sanctioned dashed borders */
  .meta-strip {
    display: flex;
    flex-wrap: wrap;
    margin-top: 28px;
    border: var(--border-sketch);
    border-radius: var(--radius-card);
    background: var(--color-card);
    overflow: hidden;
  }

  .meta-cell {
    flex: 1;
    min-width: 130px;
    padding: 16px 20px;
    border-right: var(--border-sketch);
  }

  .meta-cell:last-child {
    border-right: none;
  }

  .meta-cell b {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-purple);
  }

  .meta-cell span {
    font-family: var(--font-slab);
    font-size: 17px;
    font-weight: 600;
  }

  .meta-cell .dots {
    color: var(--color-orange-text);
    letter-spacing: 2px;
  }

  /* ---------- layout ---------- */
  .r-body {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 34px;
    align-items: start;
    padding-bottom: 40px;
  }

  /* ---------- ingredients card ---------- */
  .ing-card {
    position: sticky;
    top: 86px;
    background: var(--color-card);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    padding: 26px 28px 22px;
  }

  .ing-card h2,
  .method h2 {
    font-family: var(--font-slab);
    font-size: 22px;
    font-weight: 700;
  }

  .ing-card h2 {
    margin-bottom: 14px;
  }

  /* ---------- method ---------- */
  .method {
    background: var(--color-card);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-block);
    box-shadow: var(--shadow-block);
    padding: 36px 42px;
    min-width: 0;
  }

  .method h2 {
    margin-bottom: 22px;
  }

  .steps :global(ol) {
    list-style: none;
    counter-reset: step;
  }

  .steps :global(ol > li) {
    counter-increment: step;
    position: relative;
    padding: 0 0 26px 56px;
    font-size: var(--text-body);
    color: var(--color-soft);
  }

  .steps :global(ol > li)::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: -2px;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--color-purple-soft);
    color: var(--color-purple);
    font-family: var(--font-slab);
    font-weight: 700;
    font-size: 17px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .steps :global(ol > li:not(:last-child))::after {
    content: '';
    position: absolute;
    left: 17px;
    top: 40px;
    bottom: 6px;
    width: 2px;
    background: var(--color-line);
  }

  /* Blockquotes inside a step are Brian's margin notes */
  .steps :global(blockquote) {
    font-family: var(--font-slab);
    font-style: italic;
    font-size: 13.5px;
    color: var(--color-orange-text);
    margin-top: 6px;
  }

  /* ---------- tip block ---------- */
  .tip {
    display: flex;
    gap: 14px;
    background: var(--color-orange-tint);
    border: 1px solid var(--color-orange-soft);
    border-radius: var(--radius-card);
    padding: 18px 20px;
    margin: 6px 0 26px;
  }

  .tip :global(svg) {
    width: 20px;
    height: 20px;
    color: var(--color-orange);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .tip p {
    font-size: 14px;
  }

  /* ---------- trailing sections (Variations, Serving Ideas, …) ---------- */
  .extra {
    margin-top: 8px;
  }

  .extra h2 {
    margin-bottom: 14px;
  }

  .extra .prose {
    font-size: var(--text-body);
    color: var(--color-soft);
  }

  .extra .prose :global(p + p),
  .extra .prose :global(li + li) {
    margin-top: 8px;
  }

  .extra .prose :global(ul) {
    padding-left: 22px;
  }

  /* ---------- prev/next ---------- */
  .r-nav {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 0 30px;
    flex-wrap: wrap;
  }

  /* :global(.r-btn) — the class lands on LinkButton's own root element, which carries
     LinkButton's scope id, not this page's, so a plain scoped selector won't match. */
  .r-nav :global(.r-btn) {
    color: var(--color-purple);
    background: var(--color-card);
    border: 1px solid var(--color-line);
    padding: 12px 20px;
  }

  .r-nav :global(.r-btn):hover {
    border-color: var(--color-purple);
  }

  @media (max-width: 820px) {
    .r-hero {
      padding: 48px 0 30px;
    }

    .r-body {
      grid-template-columns: 1fr;
    }

    .ing-card {
      position: static;
    }

    .method {
      padding: 28px 24px;
    }
  }
</style>
