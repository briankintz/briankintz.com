---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Highlight from '../../components/Highlight.astro'
import TagChip from '../../components/TagChip.astro'
import { CATEGORIES, TAGS } from '../../content.config'
import { CATEGORY_LABELS, effortDots, publishedRecipes, yieldMeta } from '../../lib/recipes'

// Empty categories (breakfast, once drafts are excluded) render no heading.
const recipes = await publishedRecipes()
const sections = CATEGORIES.map((slug) => ({
  label: CATEGORY_LABELS[slug],
  recipes: recipes.filter((r) => r.data.category === slug),
})).filter((s) => s.recipes.length > 0)

const chipLabel = (tag: string) => tag[0].toUpperCase() + tag.slice(1)
---

<BaseLayout
  title="The Cookbook — Brian Kintz"
  description="Brian's cookbook — dinners, breads, sauces, snacks, and desserts, documented loosely and measured loosely too."
>
  <main class="wrap">
    <div class="hero">
      <h1>The <Highlight>Cookbook</Highlight></h1>
      <p>
        Nothing too serious — just documentation of things I've enjoyed cooking over the years. Fair warning: <em
          >I hate measuring things</em
        >, so take all units with a smidgen/pinch/dash of salt.
      </p>
    </div>

    <div class="filters">
      <div class="filter-group" role="group" aria-label="Filter by category">
        <span class="filter-label">Category</span>
        <div class="chip-row">
          <button class="chip on" data-filter="category" data-value="all" aria-pressed="true"> All </button>
          {
            CATEGORIES.map((cat) => (
              <button class="chip" data-filter="category" data-value={cat} aria-pressed="false">
                {CATEGORY_LABELS[cat]}
              </button>
            ))
          }
        </div>
      </div>
      <div class="filter-group" role="group" aria-label="Filter by tag">
        <span class="filter-label">Tags</span>
        <div class="chip-row">
          <button class="chip on" data-filter="tag" data-value="all" aria-pressed="true"> All </button>
          {
            TAGS.map((tag) => (
              <button class="chip" data-filter="tag" data-value={tag} aria-pressed="false">
                {chipLabel(tag)}
              </button>
            ))
          }
        </div>
      </div>
    </div>

    {
      sections.map(({ label, recipes }) => (
        <section class="cat">
          <div class="cat-head">
            <h2>{label}</h2>
            <span>
              {recipes.length} {recipes.length === 1 ? 'recipe' : 'recipes'}
            </span>
          </div>
          <div class="cards">
            {recipes.map(({ id, data }) => {
              const { label: yieldLabel, value: yieldValue } = yieldMeta(data)
              return (
                <a class="rcard" href={`/cookbook/${id}`} data-category={data.category} data-tags={data.tags.join('|')}>
                  <h3>{data.title}</h3>
                  <p>{data.tagline}</p>
                  {data.tags.length > 0 && (
                    <div class="tags-row">
                      {data.tags.map((tag) => (
                        <TagChip tag={tag} />
                      ))}
                    </div>
                  )}
                  <div class="meta">
                    <span>
                      <b>effort</b> {effortDots(data.effort)}
                    </span>
                    <span>
                      <b>{yieldLabel.toLowerCase()}</b> {yieldValue}
                    </span>
                  </div>
                </a>
              )
            })}
          </div>
        </section>
      ))
    }

    <p class="empty-note" hidden>Nothing tagged that yet — that page of the notebook is still blank.</p>
  </main>
</BaseLayout>

<style>
  [hidden] {
    display: none !important;
  }

  main {
    padding-bottom: 30px;
  }

  .hero {
    padding: 80px 0 44px;
  }

  h1 {
    font-family: var(--font-slab);
    font-size: var(--text-h1);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .hero p {
    margin-top: 14px;
    font-size: 16.5px;
    color: var(--color-soft);
    max-width: 56ch;
  }

  .hero p em {
    color: var(--color-ink);
  }

  .filters {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 8px 0 40px;
  }

  .filter-group {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-soft);
    flex-shrink: 0;
  }

  .chip-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .chip {
    font-family: inherit;
    font-size: 13.5px;
    font-weight: 700;
    color: var(--color-soft);
    background: var(--color-card);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
    padding: 7px 16px;
    cursor: pointer;
    transition:
      border-color 0.15s,
      color 0.15s;
  }

  .chip:hover {
    border-color: var(--color-purple);
    color: var(--color-purple);
  }

  .chip.on {
    background: var(--color-purple);
    border-color: var(--color-purple);
    color: var(--color-card);
  }

  .cat {
    margin-bottom: 52px;
  }

  .cat-head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 20px;
  }

  .cat-head h2 {
    font-family: var(--font-slab);
    font-size: 24px;
    font-weight: 700;
  }

  .cat-head span {
    font-size: 13px;
    color: var(--color-soft);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .rcard {
    position: relative;
    display: block;
    background: var(--color-card);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    padding: 22px 24px 18px;
    text-decoration: none;
    color: var(--color-ink);
    overflow: hidden;
    transition:
      transform 0.15s,
      box-shadow 0.15s,
      border-color 0.15s;
  }

  .rcard:hover {
    transform: translateY(-3px) rotate(-0.3deg);
    border-color: var(--color-purple);
    box-shadow: var(--shadow-hover);
  }

  /* Orange index-card spine — annotation accent */
  .rcard::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--color-orange);
    opacity: 0.85;
  }

  .rcard h3 {
    font-family: var(--font-slab);
    font-size: 21px;
    font-weight: 700;
    margin: 6px 0 4px;
  }

  .rcard > p {
    font-family: var(--font-slab);
    font-style: italic;
    font-size: 14.5px;
    color: var(--color-soft);
    min-height: 44px;
  }

  .tags-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 10px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 14px;
    font-size: var(--text-meta);
    color: var(--color-soft);
    flex-wrap: wrap;
  }

  .meta b {
    color: var(--color-purple);
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .empty-note {
    text-align: center;
    color: var(--color-soft);
    font-size: 14px;
    padding: 8px 0 24px;
    font-family: var(--font-slab);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 52px 0 32px;
    }
  }
</style>

<script>
  const chips = [...document.querySelectorAll<HTMLButtonElement>('.chip')]
  const cards = [...document.querySelectorAll<HTMLElement>('.rcard')]
  const cats = [...document.querySelectorAll<HTMLElement>('.cat')]
  const counts = [...document.querySelectorAll<HTMLElement>('.cat-head span')]
  const note = document.querySelector<HTMLElement>('.empty-note')!

  // Single-select per group ('category' | 'tag'), AND-combined across groups.
  const selected: Record<string, string> = { category: 'all', tag: 'all' }

  function applyFilters() {
    for (const card of cards) {
      const matchesCategory = selected.category === 'all' || card.dataset.category === selected.category
      const matchesTag = selected.tag === 'all' || (card.dataset.tags || '').split('|').includes(selected.tag)
      card.hidden = !(matchesCategory && matchesTag)
    }
    for (const cat of cats) cat.hidden = !cat.querySelector('.rcard:not([hidden])')
    const filtering = selected.category !== 'all' || selected.tag !== 'all'
    for (const count of counts) count.hidden = filtering // counts describe the full category, not the filtered view
    note.hidden = cards.some((card) => !card.hidden)
  }

  for (const chip of chips)
    chip.addEventListener('click', () => {
      const group = chip.dataset.filter!
      selected[group] = chip.dataset.value!
      for (const c of chips)
        if (c.dataset.filter === group) {
          c.classList.toggle('on', c === chip)
          c.setAttribute('aria-pressed', String(c === chip))
        }
      applyFilters()
    })
</script>
