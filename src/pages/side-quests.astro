---
import BaseLayout from '../layouts/BaseLayout.astro'
import Highlight from '../components/Highlight.astro'
import QuestCard from '../components/side-quests/QuestCard.astro'

type Quest = {
  level: string
  title: string
  body: string
  accent: 'purple' | 'orange'
  icon: string // filename (no extension) in /public/quest-icons, named by what it depicts
  hero?: boolean
  feature?: boolean
  cta?: string
  href?: string
}

// Source order drives the tint alternation (odd 0-based index = tinted) and the mosaic spans.
const quests: Quest[] = [
  {
    level: 'Happy place',
    title: 'Mountains',
    accent: 'purple',
    icon: 'mountains',
    hero: true,
    body: 'Hiking, via ferrata, trail running, ... open for anything as long as we get to the top. I only have one speed (hint: not slow), but who needs to be able to climb stairs tomorrow anyway?',
  },
  {
    level: 'Rock-a-bye Brian',
    title: 'Sailing',
    accent: 'purple',
    icon: 'sailboat',
    body: 'Racing or cruising, coastal or hundreds of miles offshore. Love it all and still sleep best on a boat.',
  },
  {
    level: 'Couch concerts only',
    title: 'Guitar',
    accent: 'orange',
    icon: 'guitar',
    body: 'My trusty Taylor helps me unwind after long days. Requests accepted, quality not guaranteed.',
  },
  {
    level: 'Hiking down stinks',
    title: 'Paragliding',
    accent: 'purple',
    icon: 'paraglider',
    body: "Just don't think too hard about the airplane view while sitting in a glorified lawn chair.",
  },
  {
    level: 'Growing (like) weeds',
    title: 'Gardening',
    accent: 'orange',
    icon: 'potted-plant',
    body: "My balcony garden grows (haha) each year. Well on my way to becoming the world's best basil killer.",
  },
  {
    level: "No it's not done yet",
    title: 'Tech Toys',
    accent: 'orange',
    icon: 'smart-bulb',
    feature: true,
    body: 'Smart-enough home that only I can turn the lights on, lazily automated everything, and just enough gaming to keep in touch with friends around the world.',
  },
  {
    level: 'Confrontation therapy',
    title: 'Dancing',
    accent: 'purple',
    icon: 'dancer',
    body: "Took a course to get over the dread of dancing in public, turns out it's actually fun. Who knew.",
  },
  {
    level: 'I ♥ Moguls',
    title: 'Skiing',
    accent: 'purple',
    icon: 'skis',
    body: 'Got my DSV Instructor and moved to the Alps. Yes, I will (silently) judge your technique.',
  },
  {
    level: 'Bee-doo bee-doo bee-doo',
    title: 'Emergency Services',
    accent: 'orange',
    icon: 'siren',
    body: 'Former EMT turned volunteer firefighter. Why sleep when you can go to a lift assist instead?',
  },
  {
    level: "I'm hungry",
    title: 'Cooking',
    accent: 'orange',
    icon: 'taco',
    hero: true,
    body: 'Big enough to earn its own corner of this site — documentation of things worth cooking twice.',
    cta: 'Head to the cookbook',
    href: '/cookbook',
  },
]

const tierOf = (q: Quest): 'hero' | 'feature' | 'normal' => (q.hero ? 'hero' : q.feature ? 'feature' : 'normal')
---

<!-- reveal is progressive enhancement: hide only when JS is on, so no-JS keeps everything visible -->
<script is:inline>
  document.documentElement.classList.add('js')
</script>

<BaseLayout
  title="Side Quests — Brian Kintz"
  description="What fills the rest of Brian Kintz's calendar: mountains, paragliding, sailing, skiing, guitar, cooking, and more."
  bg="topo"
>
  <main class="wrap">
    <div class="intro reveal">
      <h1>Side <Highlight>Quests</Highlight></h1>
      <p>Work's fun, but so are lots of other things. A running list of what fills the rest of the calendar.</p>
    </div>

    <div class="quests">
      {
        quests.map((q, i) => (
          <QuestCard
            level={q.level}
            title={q.title}
            body={q.body}
            accent={q.accent}
            icon={q.icon}
            tier={tierOf(q)}
            tinted={i % 2 === 1}
            cta={q.cta}
            href={q.href}
          />
        ))
      }
    </div>
  </main>
</BaseLayout>

<script>
  const els = [...document.querySelectorAll<HTMLElement>('.reveal')]
  const reveal = (el: HTMLElement, delay: number) => {
    el.style.transitionDelay = `${delay}ms`
    el.classList.add('in')
    // drop the stagger delay once the entrance is done so it can't delay the hover transition
    setTimeout(() => (el.style.transitionDelay = ''), delay + 600)
  }

  // below-fold cards animate in as they scroll into view, staggered per batch
  const io = new IntersectionObserver(
    (entries) => {
      let i = 0
      for (const e of entries) {
        if (!e.isIntersecting) continue
        reveal(e.target as HTMLElement, i++ * 70)
        io.unobserve(e.target)
      }
    },
    { threshold: 0.12 },
  )

  // Let the hidden (opacity:0) state paint for one frame before flipping to `in` — otherwise the
  // browser collapses 0→1 into a single paint and the transition never runs (module scripts run
  // before first paint). Above-fold cards then stagger in; the rest are handed to the observer.
  requestAnimationFrame(() =>
    requestAnimationFrame(() => {
      let i = 0
      for (const el of els) {
        if (el.getBoundingClientRect().top < window.innerHeight) reveal(el, i++ * 70)
        else io.observe(el)
      }
    }),
  )

  // hard failsafe — never leave content hidden if rAF/IO never fire (e.g. backgrounded tab)
  setTimeout(() => els.forEach((el) => el.classList.add('in')), 1500)
</script>

<style>
  .intro {
    padding: 80px 0 48px;
    transition:
      opacity 0.55s cubic-bezier(0.2, 0.7, 0.3, 1),
      translate 0.55s cubic-bezier(0.2, 0.7, 0.3, 1);
  }
  .intro h1 {
    font-family: var(--font-slab);
    font-size: clamp(36px, 5.5vw, 54px);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .intro p {
    margin-top: 14px;
    font-size: 16.5px;
    color: var(--color-soft);
    max-width: 54ch;
  }

  /* dense flow lets the double-width feature cards backfill gaps and interlock */
  .quests {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    grid-auto-flow: dense;
    gap: 22px;
    padding-bottom: 56px;
  }

  /* ---------- scroll reveal (global: applies to the intro here + .reveal cards in QuestCard) ---------- */
  /* uses `translate` (not `transform`) so it never collides with the cards' hover transform */
  :global(html.js .reveal) {
    opacity: 0;
    translate: 0 14px;
  }
  :global(html.js .reveal.in) {
    opacity: 1;
    translate: 0 0;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(html.js .reveal) {
      opacity: 1 !important;
      translate: none !important;
    }
  }
</style>
