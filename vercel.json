{
  "redirects": [
    {
      "source": "/:section(dinner|snacks|sides|desserts|bread|sauces)/:slug",
      "has": [{ "type": "host", "value": "cookbook.briankintz.com" }],
      "destination": "https://briankintz.com/cookbook/:slug",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cookbook.briankintz.com" }],
      "destination": "https://briankintz.com/cookbook",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'"
        }
      ]
    }
  ]
}
